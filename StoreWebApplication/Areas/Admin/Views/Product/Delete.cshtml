@model ProductVM

<div class="card shadow border-0 my-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Delete Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <div class="border p-3 mt-4">
                <div asp-validation-summary="All"></div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Title" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Title" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.ISBN" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.ISBN" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Author" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Author" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Category.Name" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Category.Name" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <textarea asp-for="Product.Description" disabled class="form-control border-0 shadow"></textarea>
                    <label asp-for="Product.Description" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.ListPrice" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.ListPrice" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Price" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Price" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Price50" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Price50" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.Price100" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.Price100" class="ms-2"></label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Product.ImageUrl" disabled class="form-control border-0 shadow"/>
                    <label asp-for="Product.ImageUrl" class="ms-2"></label>
                    <span asp-validation-for="Product.ImageUrl" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList"  
                            disabled class="form-select border-0 shadow">
                        <option disabled selected>--Select Category--</option>
                    </select>
                    <label asp-for="Product.CategoryId" class="ms-2"></label>
                    <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                </div>
                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-danger form-control">Delete</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary form-control">
                            Back to list
                        </a>
                    </div>
                </div>
            </div>
            
        </form>
    </div>
</div>

